{
  "name": "git2report",
  "version": "1.3.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "run-p lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt src/"
  },
  "dependencies": {
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.60.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.45.0",
    "oxlint": "~1.60.0",
    "typescript": "~6.0.0",
    "vite": "^8.0.8"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "releaseNotes": "移除 Git 钩子依赖，改为实时从 Git 仓库抓取提交记录，无需初始化全局钩子\n新增项目扫描与管理（批量添加、自定义目录扫描、Git 用户名展示）\n新增多 AI 配置管理（支持多套 API 配置切换）\n新增周报/月报生成（基于存档日报 AI 智能汇总，非机械拼接）\n新增应用内一键更新（自动下载 + 重启替换，无需手动下载安装）\n新增全局消息提示组件，优化交互体验\n优化 Git 提交扫描性能（并发控制，多项目扫描更快）\n优化自动更新检查为静默模式（仅更新按钮状态，不弹窗）"
}
